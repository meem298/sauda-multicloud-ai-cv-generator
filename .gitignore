# Terraform state — NEVER commit
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
tfplan
*.tfplan

# Terraform variable files — use *.tfvars.example as templates
*.tfvars
!*.tfvars.example

# Secrets & credentials — NEVER commit
*.pem
*.key
*.p12
*.pfx
service-account.json
*-sa.json
*-credentials.json
.env
.env.*
!.env.example

# Node.js
node_modules/
npm-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts
dist/
build/
*.zip
*.tar.gz

# Docker
.dockerignore

# AI assistant working files — never publish these
CLAUDE.md
.claude/
promt
note.txt
*.local.json
